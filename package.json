{
  "name": "combokeys",
  "version": "2.1.0",
  "description": "优雅的 JavaScript 键盘组合键监听器",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "scripts": {
    "build": "bun run build.ts",
    "build:types": "tsc --emitDeclarationOnly",
    "build:all": "bun run build.ts && bun run build:types"
  },
  "keywords": [
    "keyboard",
    "shortcut",
    "hotkey",
    "keybinding",
    "combo"
  ],
  "author": "ComboKeys",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/deepwn/ComboKeys"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/node": "^25.4.0",
    "esbuild": "^0.27.3",
    "typescript": "^5.9.3"
  }
}
